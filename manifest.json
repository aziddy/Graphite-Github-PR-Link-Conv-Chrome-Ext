{
  "manifest_version": 3,
  "name": "Graphite ⇄ GitHub PR Link Converter",
  "version": "1.0.0",
  "description": "Convert the current PR page between Graphite and GitHub with a keyboard shortcut or toolbar click.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["tabs", "storage", "scripting"],
  "host_permissions": [
    "https://app.graphite.com/*",
    "https://github.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "PR Link Converter — open settings",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "commands": {
    "convert-pr-link": {
      "suggested_key": {
        "default": "Ctrl+Shift+L",
        "mac": "Command+Shift+L"
      },
      "description": "Convert the current PR page between Graphite and GitHub"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
